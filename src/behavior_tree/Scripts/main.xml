<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="MainSequence">
      <UpdateGlobalData/>
      <SelectAimMode/>
      <SelectStrategyMode/>
      <SubTree ID="StrategyDispatch"/>
      <PreprocessData/>
      <SelectAimTarget/>
      <PublishAll/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="StrategyDispatch">
    <Fallback name="StrategySelector">
      <CheckNeedRecovery/>
      <SubTree ID="HitSentryStrategy"/>
      <SubTree ID="HitHeroStrategy"/>
      <SubTree ID="ProtectedStrategy"/>
      <SubTree ID="NaviTestStrategy"/>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="HitSentryStrategy">
    <Sequence name="HitSentrySequence">
      <IsStrategyHitSentry/>
      <ExecuteHitSentryStrategy/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="HitHeroStrategy">
    <Sequence name="HitHeroSequence">
      <IsStrategyHitHero/>
      <ExecuteHitHeroStrategy/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="ProtectedStrategy">
    <Sequence name="ProtectedSequence">
      <IsStrategyProtected/>
      <ExecuteProtectedStrategy/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NaviTestStrategy">
    <Sequence name="NaviTestSequence">
      <IsStrategyNaviTest/>
      <ExecuteNaviTestStrategy/>
    </Sequence>
  </BehaviorTree>

  <TreeNodesModel>
    <Action ID="UpdateGlobalData"/>
    <Action ID="SelectAimMode"/>
    <Action ID="SelectStrategyMode"/>
    <Action ID="ExecuteHitSentryStrategy"/>
    <Action ID="ExecuteHitHeroStrategy"/>
    <Action ID="ExecuteProtectedStrategy"/>
    <Action ID="ExecuteNaviTestStrategy"/>
    <Action ID="PreprocessData"/>
    <Action ID="SelectAimTarget"/>
    <Action ID="PublishAll"/>

    <Condition ID="CheckNeedRecovery"/>
    <Condition ID="IsStrategyHitSentry"/>
    <Condition ID="IsStrategyHitHero"/>
    <Condition ID="IsStrategyProtected"/>
    <Condition ID="IsStrategyNaviTest"/>
  </TreeNodesModel>
</root>
